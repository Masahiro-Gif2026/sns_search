# =========================================================
# sns_search — 環境変数設定ファイル (テンプレート)
# =========================================================
# このファイルを .env という名前でコピーして、
# 自分のAPIキーを記入してください。
#
#   cp .env.example .env
#
# 【重要】.env は絶対に GitHub 等の公開リポジトリにコミットしないこと。
#         (.gitignore で除外済み)
# =========================================================


# ---------------------------------------------------------
# Serper.dev API キー (必須)
# ---------------------------------------------------------
# Google検索を叩くためのAPIです。
#
# 取得手順:
#   1. https://serper.dev にアクセス
#   2. 「Get Started Free」でアカウント作成 (メール認証のみ、カード不要)
#   3. ダッシュボードの「API Key」をコピー
#
# 無料枠: 初回登録時に 2,500クレジット付与 (6ヶ月で失効)
#         1回の検索で 2クレジット消費 (XとInstagramで2回検索するため)
# ---------------------------------------------------------
SERPER_API_KEY=your-serper-api-key-here


# ---------------------------------------------------------
# Google Gemini API キー (推奨。--no-classify を付ければ省略可)
# ---------------------------------------------------------
# 検索結果を要約・信頼度判定するのに使用します。
#
# 取得手順:
#   1. https://aistudio.google.com/apikey にアクセス (要 Google アカウント)
#   2. 「Create API key」でキーを生成
#   3. 生成されたキーをコピー
#
# 無料枠: 1日 250〜1,500回まで (2025年時点、モデルとリージョンで変動)
#         gemini-2.5-flash を使用
# ---------------------------------------------------------
GEMINI_API_KEY=your-gemini-api-key-here
