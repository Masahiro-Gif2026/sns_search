# =========================================================
# .gitignore — GitHub に公開しないファイル
# =========================================================

# --- 環境変数 (APIキー) ---
# 絶対にコミットしない!
.env
.env.local
.env.*.local

# --- Streamlit の Secrets (APIキー・パスワード) ---
# ローカルで動作確認する場合に作成される。commit 厳禁
.streamlit/secrets.toml
streamlit_app/.streamlit/secrets.toml

# --- 実行時に生成されるファイル ---
report.html
report_*.html
reports/

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# --- 仮想環境 ---
venv/
env/
ENV/
.venv/

# --- IDE / エディタ ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- OS 固有 ---
.DS_Store
Thumbs.db

# --- テスト・ログ ---
.pytest_cache/
.coverage
htmlcov/
*.log
